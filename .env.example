# =============================================
# PROA Service Environment Variables
# ============================================

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# JWT Configuration (shared with identity-service)
JWT_SECRET=your_jwt_secret_key_here

# Admin Token (used for /admin/orientation/* endpoints)
# ⚠️ SECURITY: Use strong random token in production
# Example: openssl rand -hex 32
ADMIN_TOKEN=your_secret_admin_token_here

# Application Configuration
APP_ENV=dev                           # dev | staging | prod
LOG_LEVEL=info                        # debug | info | warning | error
QUIZ_VERSION_ACTIVE=v2                # Active quiz version for new users

# Feature Engineering
ENGINE_MODE=rule                      # rule | ml (machine learning support)
ENGINE_VERSION=v1
ORIENTATION_VECTOR_SIZE=12            # Number of feature dimensions

# PORA Service (Ranking microservice)
PORA_SERVICE_URL=http://localhost:8080
PORA_TIMEOUT_MS=3000

# Database
DATABASE_URL=postgresql://user:password@localhost/universearch
